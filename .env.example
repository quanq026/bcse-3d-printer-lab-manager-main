# Server
PORT=3000
JWT_SECRET=bcse-vju-3dlab-secret-change-me
NODE_ENV=development

# Data directory (optional, default: ./data)
# DATA_DIR=/var/data/bcse-lab

# CORS — comma-separated list of allowed origins (no trailing slash)
# In production: set to your actual domain
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# ALLOWED_ORIGINS=https://sv01.bcse-vju.com

# Logging level: error | warn | info | debug (default: info)
LOG_LEVEL=info

# SMTP — for sending OTP emails
# Use Gmail App Password (not your real password)
# Enable 2FA → Google Account → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-lab-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=BCSE 3D Lab <your-lab-email@gmail.com>

# Alternatively, configure SMTP via Admin → Settings page in the app
#
# --- Production Checklist ---
# 1. JWT_SECRET: generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 2. ALLOWED_ORIGINS: set to your production domain
# 3. DATA_DIR: point to a persistent volume (not inside repo)
# 4. SMTP: configure or set via Admin panel after first run
